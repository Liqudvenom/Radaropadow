# Earth texture pipeline
# ------------------------------------------------------------------
# Base URL where equirectangular (2:1) Earth textures are served.
# - Default points at the public three.js R165 texture set on GitHub
#   (CORS-friendly raw.githubusercontent.com), so the globe renders
#   out-of-the-box without committing any binary assets to this repo.
# - To use your own / NASA Visible Earth assets, drop files into
#   `public/textures/` (see public/textures/README.md for required
#   filenames + recommended sources) and switch this to:
#       VITE_EARTH_TEXTURE_BASE=/textures
VITE_EARTH_TEXTURE_BASE=https://raw.githubusercontent.com/mrdoob/three.js/r165/examples/textures/planets

# Default Earth render mode at startup: 'realistic' | 'line'
VITE_EARTH_MODE=realistic

# Optional override of the realistic albedo texture filename
# (resolved relative to VITE_EARTH_TEXTURE_BASE)
VITE_EARTH_TEXTURE_DAY=earth_atmos_2048.jpg
VITE_EARTH_TEXTURE_NIGHT=earth_lights_2048.png
VITE_EARTH_TEXTURE_CLOUDS=earth_clouds_2048.png
VITE_EARTH_TEXTURE_NORMAL=earth_normal_2048.jpg
VITE_EARTH_TEXTURE_SPECULAR=earth_specular_2048.jpg
